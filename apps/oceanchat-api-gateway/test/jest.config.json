{
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/**/*.e2e-special-spec.ts"],
  "coverageDirectory": "<rootDir>/coverage",
  "moduleFileExtensions": ["js", "json", "ts"],
  "testEnvironment": "node",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@ocean.chat/authorization(|/.*)$": "<rootDir>/../../libs/authorization/src/$1",
    "^@ocean.chat/common-exceptions(|/.*)$": "<rootDir>/../../libs/common-exceptions/src/$1",
    "^@ocean.chat/i18n(|/.*)$": "<rootDir>/../../libs/i18n/src/$1",
    "^@ocean.chat/models(|/.*)$": "<rootDir>/../../libs/models/src/$1",
    "^@ocean.chat/redis(|/.*)$": "<rootDir>/../../libs/redis/src/$1",
    "^@ocean.chat/settings(|/.*)$": "<rootDir>/../../libs/settings/src/$1",
    "^@ocean.chat/nats-opentelemetry-tracing(|/.*)$": "<rootDir>/../../libs/nats-opentelemetry-tracing/src/$1",
    "^@ocean.chat/nats-jetstream-provisioner(|/.*)$": "<rootDir>/../../libs/nats-jetstream-provisioner/src/$1",
    "^@ocean.chat/tracing(|/.*)$": "<rootDir>/../../libs/tracing/src/$1",
    "^@ocean.chat/types(|/.*)$": "<rootDir>/../../libs/types/src/$1",
    "^@ocean.chat/cores(|/.*)$": "<rootDir>/../../libs/cores/src/$1"
  },
  "collectCoverage": true,
  "collectCoverageFrom": [
    "<rootDir>/src/**/*.ts",
    "!<rootDir>/src/**/*.spec.ts",
    "!<rootDir>/src/**/*.module.ts",
    "!<rootDir>/src/**/*.dto.ts",
    "!<rootDir>/src/main.ts"
  ]
}
